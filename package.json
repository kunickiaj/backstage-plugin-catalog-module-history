{
  "name": "backstage-plugin-catalog-module-history-repo",
  "version": "0.1.0",
  "private": true,
  "description": "Workspace for Backstage catalog history packages.",
  "license": "Apache-2.0",
  "engines": {
    "node": "22 || 24"
  },
  "packageManager": "yarn@4.5.0",
  "workspaces": [
    "packages/*"
  ],
  "prettier": "@backstage/cli/config/prettier.json",
  "scripts": {
    "build": "backstage-cli repo build",
    "clean": "backstage-cli repo clean",
    "lint": "backstage-cli repo lint",
    "lint:fix": "backstage-cli repo fix",
    "test": "backstage-cli repo test --passWithNoTests",
    "test:watch": "backstage-cli repo test --watch",
    "start": "backstage-cli repo start",
    "tsc": "tsc",
    "prettier:check": "prettier --ignore-unknown --check .",
    "prettier:fix": "prettier --ignore-unknown --write ."
  },
  "devDependencies": {
    "@backstage/backend-test-utils": "^1.11.4",
    "@backstage/cli": "^0.36.3",
    "@backstage/cli-defaults": "^0.1.3",
    "@jest/environment-jsdom-abstract": "^30.4.1",
    "@types/jest": "^30.0.0",
    "@types/jsdom": "^27.0.0",
    "@types/json-stable-stringify": "^1.2.0",
    "@types/node": "^24.13.2",
    "@types/pg": "^8.20.0",
    "jest": "^30.4.2",
    "jsdom": "^27.1.0",
    "prettier": "^3.8.4",
    "typescript": "~6.0.3"
  }
}
