{
  "name": "backstage-plugin-catalog-backend-module-history",
  "version": "0.1.0",
  "description": "Backstage backend module that records every catalog EntityProvider mutation into a versioned history store.",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public",
    "main": "dist/index.cjs.js",
    "types": "dist/index.d.ts"
  },
  "engines": {
    "node": "22 || 24"
  },
  "backstage": {
    "role": "backend-plugin-module",
    "pluginId": "catalog",
    "pluginPackage": "@backstage/plugin-catalog-backend"
  },
  "configSchema": "config.d.ts",
  "exports": {
    ".": "./src/index.ts",
    "./reconcile-cli": "./src/bin/reconcile.ts",
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "package.json": [
        "package.json"
      ]
    }
  },
  "scripts": {
    "build": "backstage-cli package build",
    "clean": "backstage-cli package clean",
    "lint": "backstage-cli package lint",
    "lint:fix": "backstage-cli package lint --fix",
    "test": "backstage-cli package test --passWithNoTests",
    "test:watch": "backstage-cli package test --watch",
    "start": "backstage-cli package start",
    "tsc": "tsc",
    "prepack": "backstage-cli package prepack",
    "postpack": "backstage-cli package postpack",
    "postinstall": "node scripts/symlink-self.js"
  },
  "bin": {
    "reconcile-catalog-history": "./bin/reconcile-catalog-history.js"
  },
  "files": [
    "bin",
    "config.d.ts",
    "dist",
    "migrations",
    "scripts",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "backstage",
    "backstage-plugin",
    "backend-plugin-module",
    "catalog",
    "audit",
    "history"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/kunickiaj/backstage-plugin-catalog-module-history"
  },
  "bugs": {
    "url": "https://github.com/kunickiaj/backstage-plugin-catalog-module-history/issues"
  },
  "devDependencies": {
    "@backstage/backend-test-utils": "^1.11.4",
    "@types/jest": "^30.0.0",
    "@types/json-stable-stringify": "^1.2.0",
    "@types/node": "^24.13.2",
    "@types/pg": "^8.20.0"
  },
  "dependencies": {
    "@backstage/backend-plugin-api": "^1.9.2",
    "@backstage/catalog-client": "^1.16.0",
    "@backstage/catalog-model": "^1.9.0",
    "@backstage/plugin-catalog-node": "^2.2.2",
    "@backstage/types": "^1.2.2",
    "json-stable-stringify": "^1.3.0",
    "knex": "^3.2.10",
    "pg": "^8.22.0"
  }
}
