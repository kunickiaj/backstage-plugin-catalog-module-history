{
  "name": "@kunickiaj/catalog-history-backend",
  "version": "0.1.0",
  "description": "Storage, migrations, and history service factories for the Backstage catalog history plugin family.",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public",
    "main": "dist/index.cjs.js",
    "types": "dist/index.d.ts"
  },
  "engines": {
    "node": "22 || 24"
  },
  "backstage": {
    "role": "node-library"
  },
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "package.json": [
        "package.json"
      ]
    }
  },
  "scripts": {
    "build": "backstage-cli package build",
    "clean": "backstage-cli package clean",
    "lint": "backstage-cli package lint",
    "lint:fix": "backstage-cli package lint --fix",
    "test": "backstage-cli package test --passWithNoTests",
    "test:watch": "backstage-cli package test --watch",
    "tsc": "tsc",
    "prepack": "backstage-cli package prepack",
    "postpack": "backstage-cli package postpack"
  },
  "files": [
    "dist",
    "migrations",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "backstage",
    "backstage-plugin",
    "node-library",
    "catalog",
    "audit",
    "history"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/kunickiaj/backstage-plugin-catalog-module-history",
    "directory": "packages/catalog-history-backend"
  },
  "bugs": {
    "url": "https://github.com/kunickiaj/backstage-plugin-catalog-module-history/issues"
  },
  "dependencies": {
    "@backstage/backend-plugin-api": "^1.9.2",
    "@backstage/errors": "^1.3.1",
    "@kunickiaj/catalog-history-common": "^0.1.0",
    "@kunickiaj/catalog-history-node": "^0.1.0",
    "knex": "^3.2.10",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@backstage/backend-test-utils": "^1.11.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.13.2",
    "@types/pg": "^8.20.0"
  }
}
